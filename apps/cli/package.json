{
  "name": "@leetcast/cli",
  "version": "1.0.0",
  "private": true,
  "description": "LeetCast CLI",
  "bin": {
    "leetcast": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "dev": "ts-node src/cli.ts",
    "mcp-server": "ts-node src/mcp-server.ts",
    "update-problems": "ts-node src/scripts/update-problems.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "pnpm exec eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist coverage",
    "release": "standard-version"
  },
  "dependencies": {
    "@leetcast/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "axios": "^1.6.0",
    "chalk": "^4.1.2",
    "commander": "^14.0.3",
    "dotenv": "^16.3.1",
    "elevenlabs": "^1.59.0",
    "fs-extra": "^11.1.1",
    "openai": "^6.18.0",
    "ora": "^5.4.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.8.10",
    "@types/prompts": "^2.4.6",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.3",
    "jest": "^29.7.0",
    "lint-staged": "^15.4.3",
    "prettier": "^3.5.2",
    "rimraf": "^6.0.1",
    "standard-version": "^9.5.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
