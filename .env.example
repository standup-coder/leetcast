# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/leetcast?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Object Storage (MinIO for local dev)
S3_ENDPOINT="http://localhost:9000"
S3_PUBLIC_URL="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="leetcast"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"

# OpenAI (or 阿里云百炼 DashScope 兼容模式)
# 百炼配置示例：
# OPENAI_API_KEY=sk-your-dashscope-key
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# OPENAI_MODEL=qwen-max
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o

# ElevenLabs
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
HOST_VOICE_ID=pNInz6obpg8n9YZpUI0j
ENGINEER_VOICE_ID=onwK4e9ZLuTAKqW03Ge0

# Auth (GitHub OAuth)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
